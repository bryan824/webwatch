sqlite_path = "webwatch.sqlite3"
user_agent = "webwatch/0.1 (+https://example.invalid; low-frequency page monitor)"

[server]
bind = "127.0.0.1:3000"

[scheduler]
default_interval_secs = 300
jitter_secs = 30
http_timeout_secs = 20


[[targets]]
id = "campfire-mug"
name = "Campfire Mug"
url = "https://example.com/products/campfire-mug"
enabled = true

[[targets.conditions]]
kind = "text_appears"
value = "Add to cart"

[[targets]]
id = "sale-price"
name = "Sale Price Watch"
url = "https://example.com/products/sale-item"
enabled = true

[[targets.conditions]]
kind = "price_below"
threshold_cents = 5000
price_selector = ".price"
