# webwatch watch list — seeds the database on first run.
#
# After the first run the database is authoritative. Manage targets from the web
# UI (add / delete / enable / disable), or edit this file and re-import with:
#   curl -X POST -H "Authorization: Bearer $WEBWATCH_API_TOKEN" \
#     http://127.0.0.1:3000/targets/reload
# Reload upserts every target below; it never deletes targets added elsewhere.
#
# All conditions on a target must match before an alert is sent. The examples
# below use reserved example domains — point them at the pages you care about.

# Back in stock — alert when an "Add to cart" button appears.
[[targets]]
id = "campfire-mug"
name = "Campfire Mug — back in stock"
url = "https://store.example.com/products/campfire-mug"
enabled = true

[[targets.conditions]]
kind = "text_appears"
value = "Add to cart"

# Price drop — alert when a price falls below a threshold, checked every 15 min.
[[targets]]
id = "graphics-card"
name = "Graphics Card — under $400"
url = "https://shop.example.com/gpu/rtx-4070"
enabled = true
interval_secs = 900

[[targets.conditions]]
kind = "price_below"
threshold_cents = 40000
price_selector = ".product-price"

# Tickets on sale — alert when an availability element reads "On sale".
[[targets]]
id = "concert-tickets"
name = "Concert Tickets — on sale"
url = "https://tickets.example.org/events/12345"
enabled = true

[[targets.conditions]]
kind = "selector_text_contains"
selector = ".availability"
value = "On sale"

# Sold out lifted — alert when the "Sold out" label disappears.
[[targets]]
id = "limited-print"
name = "Limited Print — no longer sold out"
url = "https://store.example.com/products/limited-print"
enabled = true

[[targets.conditions]]
kind = "text_disappears"
value = "Sold out"

# New posting — alert when a listing link exists. Disabled until you need it.
[[targets]]
id = "careers-rust"
name = "Careers — Rust role posted"
url = "https://careers.example.net/teams/platform"
enabled = false

[[targets.conditions]]
kind = "selector_exists"
selector = "a[href*='rust-engineer']"
