sqlite_path = "webwatch.sqlite3"
user_agent = "webwatch/0.1 (+https://example.invalid; low-frequency page monitor)"

[server]
bind = "127.0.0.1:3000"

[scheduler]
default_interval_secs = 300
jitter_secs = 30
http_timeout_secs = 20

[browser]
# Optional. Start Lightpanda separately, e.g.:
# docker run -p 127.0.0.1:9222:9222 lightpanda/browser:nightly
cdp_url = "ws://127.0.0.1:9222"
wait_ms = 5000


[[targets]]
id = "js-rendered-product"
name = "JS Rendered Product"
url = "https://example.com/products/js-rendered"
enabled = true

[[targets.conditions]]
kind = "selector_text_contains"
selector = "button.add-to-cart"
value = "Add to cart"

[[targets.conditions]]
kind = "price_below"
threshold_cents = 10000
price_selector = ".product-price"
